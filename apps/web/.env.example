# Presence web — environment template. Copy to apps/web/.env.local
# Public vars are exposed to the browser (safe — anon key only).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
# Base URL of the Presence API (Render in prod, localhost in dev).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Demo mode (no Supabase) — see DEMO.md
NEXT_PUBLIC_DEMO=0
