# Presence API — environment template. Copy to apps/api/.env (or use the root .env).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_URL=http://127.0.0.1:54321
REDIS_URL=redis://127.0.0.1:6379/0
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.7
# Meta (Facebook / Instagram): "mock" (default) or "live".
META_MODE=mock
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/integrations/meta/oauth/callback
META_GRAPH_VERSION=v21.0
WEB_APP_URL=http://localhost:3000
PUBLISH_POLL_SECONDS=60
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000
