# Presence API — environment template. Copy to apps/api/.env (or use the root .env).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_URL=http://127.0.0.1:54321
REDIS_URL=redis://127.0.0.1:6379/0
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# LLM_PROVIDER: "mock" (default), "anthropic", or "auto" (Claude if a key is set).
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
# Meta (Facebook / Instagram): "mock" (default) or "live".
META_MODE=mock
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/integrations/meta/oauth/callback
META_GRAPH_VERSION=v21.0
WEB_APP_URL=http://localhost:3000
PUBLISH_POLL_SECONDS=60
# AI media (video / reels): "mock" (default) or a provider, e.g. "creatify".
MEDIA_PROVIDER=mock
MEDIA_API_ID=
MEDIA_API_KEY=
MEDIA_BASE_URL=https://api.creatify.ai
VIDEO_COST_CREDITS=10
STARTER_CREDITS=100
# Billing: "mock" (default, instant upgrades) or "stripe" (Checkout + webhooks).
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=
BILLING_SUCCESS_URL=http://localhost:3000/dashboard?upgraded=1
BILLING_CANCEL_URL=http://localhost:3000/pricing
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000
AUTH_MODE=supabase
