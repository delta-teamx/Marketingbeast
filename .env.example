# ──────────────────────────────────────────────────────────────────────────
# Presence — root environment template
# Copy to `.env` and fill in. NEVER commit real secrets.
# Per-app templates also live in apps/api/.env.example and apps/web/.env.example
# ──────────────────────────────────────────────────────────────────────────

# --- Supabase (database + auth) ---
# From your Supabase project (or `supabase start` for local).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
# JWT secret used by Supabase Auth to sign access tokens (HS256). The API validates against this.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# --- Database (SQLAlchemy / Alembic) ---
# Local Supabase default. For prod, use the Supabase connection string.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- App secrets ---
# Fernet key for encrypting social OAuth tokens at rest (Phase 1+).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

# --- LLM provider (Phase 3+) ---
# Provider selector: "mock" (default, no key needed) or "anthropic".
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.7

# --- API ---
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000
