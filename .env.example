# ──────────────────────────────────────────────────────────────────────────
# Presence — root environment template
# Copy to `.env` and fill in. NEVER commit real secrets.
# Per-app templates also live in apps/api/.env.example and apps/web/.env.example
# ──────────────────────────────────────────────────────────────────────────

# --- Supabase (database + auth) ---
# From your Supabase project (or `supabase start` for local).
SUPABASE_URL=http://127.0.0.1:54321
# Anon key — used by the WEB app only (as NEXT_PUBLIC_SUPABASE_ANON_KEY).
SUPABASE_ANON_KEY=replace-me
# (No service-role key is needed: the API never uses one. It validates Supabase
# JWTs with SUPABASE_JWT_SECRET and talks to Postgres via DATABASE_URL.)
# JWT secret used by Supabase Auth to sign access tokens (HS256). The API validates against this.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# --- Database (SQLAlchemy / Alembic) ---
# Local Supabase default. For prod, use the Supabase connection string.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- App secrets ---
# Fernet key for encrypting social OAuth tokens at rest (Phase 1+).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

# --- LLM provider (Phase 3+) ---
# Provider selector: "mock" (default, no key needed), "anthropic", or "auto"
# (uses Claude when ANTHROPIC_API_KEY is set, else mock).
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# --- Meta (Facebook / Instagram) — Tier A publishing ---
# "mock" (default) uses an in-process fake; "live" hits the Graph API.
META_MODE=mock
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/integrations/meta/oauth/callback
META_GRAPH_VERSION=v21.0
# Where the OAuth callback bounces the browser back to (the web app).
WEB_APP_URL=http://localhost:3000
# How often (seconds) the Celery beat job publishes due scheduled content.
PUBLISH_POLL_SECONDS=60

# --- AI media generation (video / reels) ---
# "mock" (default, no creds; renders complete on the first poll) or a provider
# name, e.g. "creatify". Creatify auth needs BOTH an API id and key.
MEDIA_PROVIDER=mock
MEDIA_API_ID=
MEDIA_API_KEY=
MEDIA_BASE_URL=https://api.creatify.ai
# Credits charged per generated video, and starter credits granted to a new org.
VIDEO_COST_CREDITS=10
STARTER_CREDITS=100

# --- Billing (Stripe) ---
# "mock" (default) applies upgrades instantly for dev/tests; "stripe" uses real
# Checkout + signed webhooks (set the keys/price ids below).
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=
BILLING_SUCCESS_URL=http://localhost:3000/dashboard?upgraded=1
BILLING_CANCEL_URL=http://localhost:3000/pricing

# --- API ---
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000
